NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rayna_social
DB_USER=postgres
DB_PASSWORD=postgres

JWT_ACCESS_SECRET=your-access-secret-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google Sheet published as CSV — used by POST /api/v1/role/sync
# Format: role, resource, create, read, revise, remove, root
RBAC_PERMISSIONS_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# Claude AI — used for AI caption/hashtag generation
CLAUDE_API_KEY=sk-ant-your-claude-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI — used for AI caption/hashtag/carousel generation
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Cloudinary — image/video storage + processing
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# PostForMe — unified social media API (https://postforme.dev)
POSTFORME_API_KEY=your-postforme-api-key
POSTFORME_BASE_URL=https://api.postforme.dev
POSTFORME_WEBHOOK_SECRET=your-postforme-webhook-secret
